{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "RocChat",
  "version": "1.0.0",
  "identifier": "com.rocchat.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../web && npm run dev",
    "beforeBuildCommand": "cd ../../web && npm run build"
  },
  "app": {
    "title": "RocChat",
    "windows": [
      {
        "title": "RocChat",
        "width": 1024,
        "height": 768,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "RocChat"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://rocchat-api.spoass.workers.dev wss://rocchat-api.spoass.workers.dev https://chat.mocipher.com wss://chat.mocipher.com https://ntfy.roc.family; img-src 'self' data: blob:; media-src 'self' blob:; frame-ancestors 'none'; base-uri 'none'; form-action 'self'; worker-src 'self'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {}
    },
    "linux": {
      "appimage": {}
    }
  },
  "plugins": {
    "notification": {},
    "autostart": {
      "macosExtraLaunchAgentConfig": {}
    },
    "deep-link": {
      "desktop": {
        "schemes": ["rocchat"]
      }
    }
  }
}
