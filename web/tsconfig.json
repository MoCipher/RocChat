{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@rocchat/shared": ["../shared"]
    }
  },
  "include": ["src", "../shared"]
}
